And add this JS near the bottom before </body>:

<script>
  const heroBall = document.getElementById("heroBall");
  const heroVisual = document.querySelector(".hero-visual");

  function updateBallByScroll() {
    if (!heroBall || !heroVisual) return;

    const rect = heroVisual.getBoundingClientRect();
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight;

    const progress = Math.max(
      -1,
      Math.min(1, (viewportHeight * 0.5 - rect.top - rect.height * 0.5) / viewportHeight)
    );

    const rotateZ = progress * 38;
    const rotateX = progress * -10;
    const translateY = progress * -18;
    const translateX = progress * 10;

    heroBall.style.transform =
      `translate3d(${translateX}px, ${translateY}px, 0) rotateX(${rotateX}deg) rotateZ(${rotateZ}deg)`;
  }

  let scrollTicking = false;

  function handleScrollBall() {
    if (!scrollTicking) {
      window.requestAnimationFrame(() => {
        updateBallByScroll();
        scrollTicking = false;
      });
      scrollTicking = true;
    }
  }

  window.addEventListener("scroll", handleScrollBall, { passive: true });
  window.addEventListener("resize", updateBallByScroll);
  window.addEventListener("load", updateBallByScroll);
</script>
One note: your original uploaded file looks partial and stops around the Match Centre section, so I built this on the fuller homepage version we had been working from. If you want, next I can make the ball react to both mouse movement and scroll so it feels even more premium.


